FUNCTION_BLOCK "FB_ForeAftDamping"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_FA_Acc : Real;
      i_enable : Bool;
   END_VAR

   VAR_OUTPUT 
      q_FA_PitCom : Real;
   END_VAR

   VAR_TEMP 
      FA_AccHPF : LReal;
      FA_AccHPFI : Real;
   END_VAR

   VAR CONSTANT 
      FA_KI : Real := 0.025;
      FA_HPF_CornerFreq : Real := 0.15;
      FA_IntSat : Real := 0.087;
   END_VAR


BEGIN
	"inst_AccHPF"(i_signal:=#i_FA_Acc,
	              i_DT:=0.0125,
	              i_freq:=#FA_HPF_CornerFreq,
	              i_reset:=NOT "DatosGlobales".g_bldPitchAutoMode,
	              i_useInicialValue:=FALSE,
	              i_initialValue:=0.0,
	              q_fignal_flt=>#FA_AccHPF);
	
	
	"inst_AccPI"(i_error:=#FA_AccHPF,
	                  i_kp:=0.0,
	                  i_ki:=#FA_KI,
	                  i_minValue:=-#FA_IntSat,
	                  i_maxValue:=#FA_IntSat,
	                  i_DT:=0.0125,
	                  i_I0:=0.0,
	                  i_Reset:=NOT "DatosGlobales".g_bldPitchAutoMode ,
	                  q_PIController=>#FA_AccHPFI);
	
	IF #i_enable THEN
	    #q_FA_PitCom := #FA_AccHPFI;
	ELSE
	    #q_FA_PitCom := 0.0;
	END_IF;
	
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_LPFilter"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_LPfilter : Real;
      i_DT : Real;
      i_freq : Real;
      i_reset : Bool;
   END_VAR

   VAR_OUTPUT 
      q_flt_sign : Real;
   END_VAR

   VAR 
      stat_x_ant : Real;
      stat_y_ant : Real;
      stat_a1 : Real;
      stat_a0 : Real;
      stat_b1 : Real;
      stat_b0 : Real;
      stat_init_done : Bool := FALSE;
   END_VAR


BEGIN
	
	IF (NOT #"stat_init_done") OR #i_reset THEN
	    #stat_x_ant := #i_LPfilter;
	    #stat_y_ant := #i_LPfilter;
	    #stat_a1 := 2.0 + (#i_freq * #i_DT);
	    #stat_a0 := (#i_freq * #i_DT) - 2.0;
	    #stat_b1 := #i_freq * #i_DT;
	    #stat_b0 := #i_freq * #i_DT;
	    
	    #"stat_init_done" := TRUE;
	END_IF;
	
	// ecuacion del filtro
	#q_flt_sign := (1.0 / #stat_a1) * ((- #stat_a0 * #stat_y_ant) + (#stat_b1 * #i_LPfilter) + (#stat_b0 * #stat_x_ant));
	
	
	#stat_x_ant := #i_LPfilter;
	#stat_y_ant := #q_flt_sign;
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_NotchFilterSlopes"
TITLE = 'Notch Filter Slopes'
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// Discrete time inverted Notch Filter with descending slopes
// G = CornerFreq*s/(Damp*s^2+CornerFreq*s+Damp*CornerFreq^2)
   VAR_INPUT 
      i_signal : LReal;
      i_DT : LReal;
      i_freq : LReal;
      i_damp : LReal;
      i_status : Int;
      i_reset : Bool;
      i_moving : Bool;
      i_useInitialValue : Bool;
      i_nitialValue : LReal;
   END_VAR

   VAR_OUTPUT 
      q_signal_flt : LReal;
   END_VAR

   VAR 
      OutputSignalLast1 : LReal;
      OutputSignalLast2 : LReal;
      InputSignalLast1 : LReal;
      InputSignalLast2 : LReal;
      b2 : LReal;
      b0 : LReal;
      a2 : LReal;
      a1 : LReal;
      a0 : LReal;
   END_VAR

   VAR_TEMP 
      "InitialValue_" : LReal;
      "CornerFreq_" : LReal;
   END_VAR


BEGIN
	
	IF #i_useInitialValue THEN
	    #"InitialValue_" := #i_nitialValue;
	ELSE
	    #"InitialValue_" := #i_signal;
	END_IF;
	
	IF #i_freq < 0.0 THEN
	    #"CornerFreq_" := 0.0;
	ELSE
	    #"CornerFreq_" := #i_freq;
	END_IF;
	
	
	IF (#i_status = 0) OR #i_reset THEN
	    #OutputSignalLast1 := #"InitialValue_";
	    #OutputSignalLast2 := #"InitialValue_";
	    #InputSignalLast1 := #"InitialValue_";
	    #InputSignalLast2 := #"InitialValue_";
	END_IF;
	
	IF (#i_status = 0) OR #i_reset OR #i_moving THEN
	    #b2 := 2.0 * #i_DT * #"CornerFreq_";
	    #b0 := - #b2;
	    
	    #a2 := #i_damp * (#i_DT * #i_DT) * (#"CornerFreq_" * #"CornerFreq_") + 2.0 * #i_DT * #"CornerFreq_" + 4.0 * #i_damp;
	    #a1 := 2.0 * #i_damp * (#i_DT * #i_DT) * (#"CornerFreq_" * #"CornerFreq_") - 8.0 * #i_damp;
	    #a0 := #i_damp * (#i_DT * #i_DT) * (#"CornerFreq_" * #"CornerFreq_") - 2.0 * #i_DT * #"CornerFreq_" + 4.0 * #i_damp;
	END_IF;
	
	
	// CORRECCIÓN: Cambiar #InputSignalLast1 por #InputSignalLast2 en el multiplicador de #b0
	IF #a2 <> 0.0 THEN
	    #q_signal_flt := (1.0 / #a2) * ((#b2 * #i_signal) + (#b0 * #InputSignalLast1) - (#a1 * #OutputSignalLast1) - (#a0 * #OutputSignalLast2));
	ELSE
	    #q_signal_flt := #i_signal;
	END_IF;
	
	#InputSignalLast2 := #InputSignalLast1;
	#InputSignalLast1 := #i_signal;
	
	#OutputSignalLast2 := #OutputSignalLast1;
	#OutputSignalLast1 := #q_signal_flt;
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_SecLPFilter"
TITLE = 'Filtro Paso Bajo de Segundo Orden'
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_signal : LReal;
      i_DT : LReal;
      i_freq : LReal;
      i_damp : LReal;
      i_reset : Bool;
      i_useInitialValue : Bool;
      i_initialValue : LReal;
   END_VAR

   VAR_OUTPUT 
      q_signal_flt : Real;
   END_VAR

   VAR 
      FirstRun : Bool := TRUE;
      InputSignalLast1 : LReal;
      InputSignalLast2 : LReal;
      OutputSignalLast1 : LReal;
      OutputSignalLast2 : LReal;
      a0 : LReal;
      a1 : LReal;
      a2 : LReal;
      b0 : LReal;
      b1 : LReal;
      b2 : LReal;
   END_VAR

   VAR_TEMP 
      temp_initVal : LReal;
   END_VAR


BEGIN
	IF #i_useInitialValue THEN
	    #temp_initVal := #i_initialValue;
	ELSE
	    #temp_initVal := #i_signal;
	END_IF;
	    
	
	IF #FirstRun OR #i_reset THEN
	    
	    #OutputSignalLast1 := #temp_initVal;
	    #OutputSignalLast2 := #temp_initVal;
	    #InputSignalLast1 := #temp_initVal;
	    #InputSignalLast2 := #temp_initVal;
	    
	    
	    #a2 := (#i_DT ** 2.0 * #i_freq ** 2.0) + 4.0 + (4.0 * #i_damp * #i_freq * #i_DT);
	    #a1 := (2.0 * #i_DT ** 2.0 * #i_freq ** 2.0) - 8.0;
	    #a0 := (#i_DT ** 2.0 * #i_freq ** 2.0) + 4.0 - (4.0 * #i_damp * #i_freq * #i_DT);
	    
	    #b2 := (#i_DT ** 2.0 * #i_freq ** 2.0);
	    #b1 := (2.0 * #i_DT ** 2.0 * #i_freq ** 2.0);
	    #b0 := (#i_DT ** 2.0 * #i_freq ** 2.0);
	    
	    
	    #FirstRun := FALSE;
	END_IF;
	
	
	#q_signal_flt := LREAL_TO_REAL((1.0 / #a2) * ((#b2 * #i_signal) +
	(#b1 * #InputSignalLast1) +
	(#b0 * #InputSignalLast2) -
	(#a1 * #OutputSignalLast1) -
	(#a0 * #OutputSignalLast2)));
	
	
	#InputSignalLast2 := #InputSignalLast1;
	#InputSignalLast1 := #i_signal;
	#OutputSignalLast2 := #OutputSignalLast1;
	#OutputSignalLast1 := #q_signal_flt;
	    
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_SetPointSmoother"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_enable_smoothing : Bool;
      i_bldPitch1 : Real;
      i_pitchMin : Real;
      i_pwrRated : Real;
      i_pwrMedido : Real;
      i_refSpeed : Real;
      i_gainVS : Real;
      i_gainPC : Real;
      i_freq : Real;
      i_DT : Real := 0.0125;
   END_VAR

   VAR_OUTPUT 
      q_omega_flt : Real;
   END_VAR

   VAR 
      stat_xAnt : Real;
      stat_InitDone : Bool;
   END_VAR

   VAR_TEMP 
      temp_omegaRaw : Real;
      temp_alpha : Real;
      temp_a1 : Real;
      temp_a0 : Real;
      temp_b : Real;
   END_VAR


BEGIN
	
	IF #i_enable_smoothing THEN
	    #temp_omegaRaw := (((#i_bldPitch1 - #i_pitchMin) / 0.524) * #i_gainVS) -
	    (((#i_pwrRated) - #i_pwrMedido) / #i_pwrRated * #i_gainPC);
	    #temp_omegaRaw := #temp_omegaRaw * #i_refSpeed;
	    
	    
	
	    IF NOT #stat_InitDone THEN
	        #q_omega_flt := #temp_omegaRaw;
	        #stat_xAnt := #temp_omegaRaw;
	        #stat_InitDone := TRUE;
	    END_IF;
	
	    #temp_a1 := 2.0 + (#i_freq * #i_DT);
	    #temp_a0 := (#i_freq * #i_DT) - 2.0;
	    #temp_b := #i_freq * #i_DT;
	    
	    #q_omega_flt := (1.0 / #temp_a1) * (- (#temp_a0 * #q_omega_flt) + (#temp_b * #temp_omegaRaw) + (#temp_b * #stat_xAnt));
	    
	    // Actualizar memorias para el siguiente ciclo
	    #stat_xAnt := #temp_omegaRaw;
	    
	ELSE
	    #q_omega_flt := 0.0;
	    #stat_InitDone := FALSE; // forzar reinicio si se reactiva el smoothing
	END_IF;
END_FUNCTION_BLOCK

FUNCTION "FC_ColemanTransform" : Void
TITLE = 'Coleman Transform (d-q axis)'
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// Transforms root out-of-plane bending moments to direct and quadrature axes
   VAR_INPUT 
      i_rootMOOP : Array[1..3] of LReal;
      i_aziAngle : LReal;
      i_nHarmonic : Int;
   END_VAR

   VAR_OUTPUT 
      q_axTOut : Real;
      q_axYOut : Real;
   END_VAR

   VAR_TEMP 
      temp_phi2 : LReal;
      temp_phi3 : LReal;
      temp_harmonic : LReal;
   END_VAR

   VAR CONSTANT 
      PI : Real := 3.141593;
   END_VAR


BEGIN
	#temp_phi2 := (2.0 / 3.0) * #PI;
	#temp_phi3 := (4.0 / 3.0) * #PI;
	#temp_harmonic := INT_TO_LREAL(#i_nHarmonic);
	#q_axTOut := LREAL_TO_REAL((2.0 / 3.0) * (
	(COS(#temp_harmonic * #i_aziAngle) * #i_rootMOOP[1]) +
	(COS(#temp_harmonic * (#i_aziAngle + #temp_phi2)) * #i_rootMOOP[2]) +
	(COS(#temp_harmonic * (#i_aziAngle + #temp_phi3)) * #i_rootMOOP[3])
	));
	#q_axYOut := LREAL_TO_REAL((2.0 / 3.0) * (
	(SIN(#temp_harmonic * #i_aziAngle) * #i_rootMOOP[1]) +
	(SIN(#temp_harmonic * (#i_aziAngle + #temp_phi2)) * #i_rootMOOP[2]) +
	(SIN(#temp_harmonic * (#i_aziAngle + #temp_phi3)) * #i_rootMOOP[3])
	));
END_FUNCTION

