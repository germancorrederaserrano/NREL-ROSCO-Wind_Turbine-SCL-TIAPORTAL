      g_paroEmerg : Bool;
      g_timeCpu : Time;
      g_IPC_activo : Bool;
      g_setpointS_activo : Bool;
      g_peakS_activo : Bool;
      g_FA_activo : Bool;
      g_stop_start_up : Bool;
   END_VAR


BEGIN
   g_torqAutoMode := TRUE;
   g_bldPitchAutoMode := TRUE;
   g_IPC_activo := TRUE;
