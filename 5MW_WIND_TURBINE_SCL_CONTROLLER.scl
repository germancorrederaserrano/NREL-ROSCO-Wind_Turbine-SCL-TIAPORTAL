FUNCTION "FC_Sigma" : Real
TITLE = 'Generic Sigma Function'
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// Creado para Soft Cut-in. InterpolaciÃ³n cÃºbica suave entre (x0, y0) y (x1, y1)
   VAR_INPUT 
      x : LReal;
      x0 : LReal;
      x1 : LReal;
      y0 : LReal;
      y1 : LReal;
   END_VAR

   VAR_TEMP 
      t_dx : LReal;
      t_dx3 : LReal;
      t_a3 : LReal;
      t_a2 : LReal;
      t_a1 : LReal;
      t_a0 : LReal;
      t_x2 : LReal;
      t_x3 : LReal;
   END_VAR


BEGIN
	IF #x <= #x0 THEN
	    #FC_Sigma := #y0;
	    RETURN;
	ELSIF #x >= #x1 THEN
	    #FC_Sigma := #y1;
	    RETURN;
	END_IF;
	
	#t_dx := #x0 - #x1;
	
	IF ABS(#t_dx) < 1.0E-6 THEN
	    #FC_Sigma := #y1;
	    RETURN;
	END_IF;
	
	#t_dx3 := #t_dx * #t_dx * #t_dx;
	#t_x2 := #x * #x;
	#t_x3 := #t_x2 * #x;
	
	#t_a3 := 2.0 / #t_dx3;
	#t_a2 := -3.0 * (#x0 + #x1) / #t_dx3;
	#t_a1 := 6.0 * #x1 * #x0 / #t_dx3;
	#t_a0 := (#x0 - 3.0 * #x1) * (#x0 * #x0) / #t_dx3;
	
	#FC_Sigma := LREAL_TO_REAL(((#t_a3 * #t_x3) + (#t_a2 * #t_x2) + (#t_a1 * #x) + #t_a0) * (#y1 - #y0) + #y0);
	
END_FUNCTION

FUNCTION "FC_ColemanTransformInverse" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_axTIn : LReal;
      i_axYIn : LReal;
      i_aziAngle : LReal;
      i_aziOffset : LReal;
      i_nHarmonic : Int;
   END_VAR

   VAR_OUTPUT 
      q_pitComIPC : Array[1..3] of LReal;
   END_VAR

   VAR_TEMP 
      temp_nHarmonicLR : LReal;
      temp_baseAngle : LReal;
   END_VAR

   VAR CONSTANT 
      PI : LReal := 3.14159265358979;
      PHI2 : LReal := 2.0943951023932;
      PHI3 : LReal := 4.18879020478639;
   END_VAR


BEGIN
	#temp_nHarmonicLR := INT_TO_LREAL(#i_nHarmonic);
	#temp_baseAngle := #i_aziAngle + #i_aziOffset;
	
	// Blade 1
	#q_pitComIPC[1] := COS(#temp_nHarmonicLR * #temp_baseAngle) * #i_axTIn
	+ SIN(#temp_nHarmonicLR * #temp_baseAngle) * #i_axYIn;
	
	// Blade 2
	#q_pitComIPC[2] := COS(#temp_nHarmonicLR * (#temp_baseAngle + #PHI2)) * #i_axTIn
	+ SIN(#temp_nHarmonicLR * (#temp_baseAngle + #PHI2)) * #i_axYIn;
	
	// Blade 3
	#q_pitComIPC[3] := COS(#temp_nHarmonicLR * (#temp_baseAngle + #PHI3)) * #i_axTIn
	+ SIN(#temp_nHarmonicLR * (#temp_baseAngle + #PHI3)) * #i_axYIn;
END_FUNCTION

FUNCTION_BLOCK "FB_VariableSpeedController"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_genSpeed_rpm : Real;
      i_bldPitch1 : Real;
   END_VAR

   VAR_OUTPUT 
      q_genTq_Nm : Real;
   END_VAR

   VAR 
      stat_last_genTq : Real;
      stat_VS_state : Real := 1.0;
   END_VAR

   VAR_TEMP 
      temp_VS_minOMTq : Real;
      temp_VS_maxOMTq : Real;
      temp_genSpeed_flt_rads : Real;
      temp_genSpeed_rads : Real;
      temp_VS_spdErrAr : Real;
      temp_VS_refSpd : Real;
      temp_genBrTq : Real;
      temp_genArTq : Real;
      temp_VS_spdErrBr : Real;
      temp_VS_constPwr_genTq : Real;
      temp_VS_kOmega2_genTq : Real;
      temp_torqueRef : Real;
      temp_torqueRate : Real;
   END_VAR

   VAR CONSTANT 
      VS_MINOMSPD : Real := 34.68;
      VS_ARSATTQ : Real := 43093.51;
      VS_RGN2K : Real := 2.526;
      VS_RTPWR : Real := 5000000.0;
      VS_GENEFF : Real := 94.4;
      VS_REGION_1 : Real := 70.26;
      RATE_GENSPEED : Real := 122.9;
      RATE_TQ : Real := 43093.55;
      MAX_TQ : Real := 47402.91;
      MAX_RATE_TQ : Real := 15000.0;
      RPM_TO_RADS : Real := 0.104719;
      DEG_TO_RAD : Real := 0.01745329;
      DTIME : Real := 0.0125;
      LPF_FQ : Real := 1.5708;
      KP_VS : Real := -988.02;
      KI_VS : Real := -185.79;
      MIN_TQ : Real := 0.0;
      REGION_3_PWRCONST : Real := 3.0;
      "REGION_2.5" : Real := 2.5;
      REGION_2 : Real := 2.0;
      "REGION_1.5" : Real := 1.5;
      REGION_1 : Real := 1.0;
      NON_REGION : Real := -1.0;
   END_VAR


BEGIN
	#temp_genSpeed_rads := #i_genSpeed_rpm * #RPM_TO_RADS; //la entrada de simulink (OpenFAST) está en rpm.
	
	//filtramos la velocidad del generador
	"inst_FiltroGenSpeed"(i_LPfilter:=#temp_genSpeed_rads,
	                i_DT:=#DTIME,
	                i_freq:=#LPF_FQ,
	                i_reset:=FALSE,
	                q_flt_sign=>#temp_genSpeed_flt_rads);
	
	//ComputeVariableReferences
	#temp_VS_refSpd := #RATE_GENSPEED;
	IF "Inst_SetpointS".q_omega_flt > 0 THEN
	    #temp_VS_refSpd := #temp_VS_refSpd - "Inst_SetpointS".q_omega_flt;
	END_IF;
	
	//PI para regiones .5
	#temp_VS_spdErrAr := #temp_VS_refSpd - #temp_genSpeed_flt_rads;  
	#temp_VS_maxOMTq := #VS_RGN2K * #temp_VS_refSpd *#temp_VS_refSpd; 
	"inst_PI_2_5"(i_error := #temp_VS_spdErrAr,
	                          i_kp := #KP_VS,
	                          i_ki := #KI_VS,
	                          i_minValue := #temp_VS_maxOMTq,
	                          i_maxValue := #VS_ARSATTQ,
	                          i_DT := #DTIME,
	                          i_I0 := #temp_VS_maxOMTq,
	                          i_Reset := NOT "DatosGlobales".g_torqAutoMode,
	                          q_PIController => #temp_genArTq);
	
	#temp_VS_spdErrBr := #VS_MINOMSPD - #temp_genSpeed_flt_rads;
	#temp_VS_minOMTq := #VS_RGN2K * #VS_MINOMSPD*#VS_MINOMSPD;
	"inst_PI_1_5"(i_error := #temp_VS_spdErrBr,
	                            i_kp := #KP_VS,
	                            i_ki := #KI_VS,
	                            i_minValue := 0.0,
	                            i_maxValue := #temp_VS_minOMTq,
	                            i_DT := #DTIME,
	                            i_I0 := #temp_VS_minOMTq,
	                            i_Reset := NOT "DatosGlobales".g_torqAutoMode,
	                            q_PIController => #temp_genBrTq);
	
	// calculamos torque para potencia constante (para la region III) -> P = W_angular * Torque.
	#temp_VS_constPwr_genTq := #VS_RTPWR / (#VS_GENEFF / 100.0) / #temp_genSpeed_flt_rads;
	              
	//para la region 2: el torque optimo T = kw^2              
	#temp_VS_kOmega2_genTq := #VS_RGN2K * #temp_genSpeed_flt_rads * #temp_genSpeed_flt_rads;
	
	// condiciones para la maquina de estados del generador. Solo si esta en modo automatico y no esta en paro de emergencia
	IF "DatosGlobales".g_torqAutoMode AND NOT "DatosGlobales".g_paroEmerg THEN
	    IF (#i_bldPitch1 >= (1.0*#DEG_TO_RAD) + ("Inst_PeakS".g_bldPitchMinSS +"Inst_ForeAftDamping".q_FA_PitCom+"IPC".PitComIPC_1P[0])) AND "DatosGlobales".g_bldPitchAutoMode THEN  //Entramos en la region III
	        #stat_VS_state := #REGION_3_PWRCONST;
	    ELSE
	        IF #temp_genArTq >= #temp_VS_maxOMTq * 1.01 THEN   // REGION 2 1/2 - activamos PI para el control del torque
	            #stat_VS_state := #"REGION_2.5";
	        ELSIF #temp_genSpeed_flt_rads < #temp_VS_refSpd AND #temp_genBrTq >= #temp_VS_minOMTq THEN //REGION 2 - proporcional k w
	            #stat_VS_state := #REGION_2;
	        ELSIF #temp_genBrTq < #temp_VS_minOMTq THEN //REGION 1 1/2 - active PI control
	            #stat_VS_state := #"REGION_1.5";
	        ELSIF #temp_genSpeed_flt_rads < #VS_REGION_1 THEN //REGION 1
	            #stat_VS_state := #REGION_1;
	        END_IF;
	    END_IF;
	    
	    
	    // maquina de estados
	    IF #stat_VS_state = #REGION_1 THEN
	        #temp_torqueRef := #MIN_TQ;
	    ELSIF #stat_VS_state = #"REGION_1.5" THEN
	        #temp_torqueRef := #temp_genBrTq;
	    ELSIF #stat_VS_state = #REGION_2 THEN
	        #temp_torqueRef := #temp_VS_kOmega2_genTq;
	    ELSIF #stat_VS_state = #"REGION_2.5" THEN
	        #temp_torqueRef := #temp_genArTq;
	    ELSIF #stat_VS_state = #REGION_3_PWRCONST THEN
	        #temp_torqueRef := #temp_VS_constPwr_genTq;
	    ELSE //estado de debug
	        #stat_VS_state := #stat_VS_state;
	    END_IF;
	    
	    
	END_IF;
	
	
	    //Modo manual 
	IF NOT "DatosGlobales".g_torqAutoMode THEN
	    // referencia directamente pasada de la variable manual (lazo 'abierto' computacionalmente hablando)
	    #temp_torqueRef := "DatosGlobales".g_torqManualValue;
	    #stat_VS_state := #NON_REGION;
	END_IF;
	
	
	IF "DatosGlobales".g_paroEmerg THEN
	    // automaticamente a 0.0 y ponemos el modo manual
	    "DatosGlobales".g_torqAutoMode := FALSE;
	    #temp_torqueRef := 0.0;
	    #stat_VS_state := #NON_REGION;
	END_IF;
	
	//pasar al scada
	"DatosGlobales".g_torqManualValue := REAL_TO_DINT(#temp_torqueRef);
	// se puede pasar antes de los limites, para ver el setpoint directamente
	// o despues de los limites, para ver el valor real
	
	// limitador de tasa de cambio
	#temp_torqueRate := (#temp_torqueRef - #stat_last_genTq) / #DTIME;
	IF #temp_torqueRate > #MAX_RATE_TQ THEN
	    #temp_torqueRef := #stat_last_genTq + #MAX_RATE_TQ * #DTIME;
	ELSIF #temp_torqueRate < - #MAX_RATE_TQ THEN
	    #temp_torqueRef := #stat_last_genTq - #MAX_RATE_TQ * #DTIME;
	END_IF;
	// saturación de los límites de par
	IF #temp_torqueRef > #MAX_TQ THEN
	    #temp_torqueRef := #MAX_TQ;
	END_IF;
	IF #temp_torqueRef < #MIN_TQ THEN
	    #temp_torqueRef := #MIN_TQ;
	END_IF;
	
	//guardamos el paso anterior
	#stat_last_genTq := #temp_torqueRef;
	//salida hacia simulink
	#q_genTq_Nm := #temp_torqueRef;
	
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_PitchController"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_genSpeed_rpm : Real;
      i_bldPitch1 : LReal;
      i_ncIMUTAxs : LReal;
   END_VAR

   VAR_OUTPUT 
      q_bldPitch3_rad : Real;
      q_bldPitch2_rad : Real;
      q_bldPitch1_rad : Real;
   END_VAR

   VAR 
      stat_lastBldPitch : Real;
      stat_FA_PitCom : Real;
      Stat_PC_SpdErr : Real;
      stat_lastBldPitch_deg : Real;
      stat_bldPitches : Array[0..2] of Real;
      stat_lastBldPitches : Array[0..2] of Real;
      stat_shutdown_ok : Bool;
   END_VAR

   VAR_TEMP 
      temp_genSpeed_rads : Real;
      temp_GenSpeed_flt_rads : Real;
      temp_PC_refSpd : Real;
      temp_bldPitch1_deg : Real;
      temp_bldPitch1_flt : Real;
      temp_bldPitchRef : Real;
      temp_bldPitchRate : Real;
      temp_bldPitchRef_rad : Real;
      temp_k_i : Real;
      temp_k_p : Real;
      temp_i : Int;
   END_VAR

   VAR CONSTANT 
      VS_REGION_1 : Real := 70.26;
      MAX_PITCH : Real := 1.57;
      MIN_PITCH : Real := 0.0;
      MAX_PITCH_RATE : Real := 0.1396;
      DTIME : Real := 0.0125;
      RPM_TO_RADS : Real := 0.1047198;
      RAD_TO_DEG : Real := 57.29578;
      LPF_FQ : Real := 1.5708;
      RATE_VS : Real := 122.9;
   END_VAR


BEGIN
	// entrada de simulink (salida de OpenFAST) en rpm
	#temp_genSpeed_rads := #i_genSpeed_rpm * #RPM_TO_RADS;
	
	// filtramos la velocidad del generador 
	"inst_FiltroGenSpeed"(i_LPfilter:=#temp_genSpeed_rads,
	                 i_DT:=#DTIME,
	                 i_freq:=#LPF_FQ,
	                 i_reset:=FALSE,
	                 q_flt_sign=>#temp_GenSpeed_flt_rads);
	
	// filtramos el pitch de entrada
	"inst_BldPitchSecLPFilter"(i_signal:=#i_bldPitch1,
	                 i_DT:=#DTIME,
	                 i_freq:=#LPF_FQ*0.25,
	                 i_damp:=0.7,
	                 i_reset:=FALSE,
	                 i_useInitialValue:=FALSE,
	                 q_signal_flt=>#temp_bldPitch1_flt);
	
	// ajustamos setpoint con la función SS
	#temp_PC_refSpd := #RATE_VS;
	IF "Inst_SetpointS".q_omega_flt < 0 THEN
	    #temp_PC_refSpd := #temp_PC_refSpd - "Inst_SetpointS".q_omega_flt;
	END_IF;
	
	
	//Control pitch
	
	#temp_bldPitch1_deg := LREAL_TO_REAL(#temp_bldPitch1_flt) * #RAD_TO_DEG;
	
	// limites del gain scheduling
	IF #temp_bldPitch1_deg < 3.0 THEN
	    #temp_k_i := -0.005486;
	    #temp_k_p := -0.014943;
	ELSIF #temp_bldPitch1_deg > 23.0 THEN
	    #temp_k_i := -0.001338;
	    #temp_k_p := -0.000912;
	ELSE  // polinomio de segundo grado aproximado al unir los puntos de la recta proporcionada por ROSCO
	    #temp_k_p := (-0.0000304 * (#temp_bldPitch1_deg * #temp_bldPitch1_deg)) + (0.0014813 * #temp_bldPitch1_deg) - 0.0191187;
	    #temp_k_i := (-0.00000898 * (#temp_bldPitch1_deg * #temp_bldPitch1_deg)) + (0.0004379 * #temp_bldPitch1_deg) - 0.0067204;
	END_IF;
	
	// calculamos el error
	#Stat_PC_SpdErr := #temp_PC_refSpd - #temp_GenSpeed_flt_rads;
	"inst_BldPitchPI"(i_error := #Stat_PC_SpdErr,
	                  i_kp := #temp_k_p,
	                  i_ki := #temp_k_i,
	                  i_minValue := "Inst_PeakS".g_bldPitchMinSS,
	                  i_maxValue := #MAX_PITCH,
	                  i_DT := #DTIME,
	                  i_I0 := LREAL_TO_REAL(#i_bldPitch1),
	                  i_Reset := NOT "DatosGlobales".g_bldPitchAutoMode,
	                  "q_PIController" => #temp_bldPitchRef);
	// le sumo el efecto de FA
	#temp_bldPitchRef := #temp_bldPitchRef + "Inst_ForeAftDamping".q_FA_PitCom;
	
	// aplico el minimo de PS (se aplica al CPC no al IPC )
	IF #temp_bldPitchRef < "Inst_PeakS".g_bldPitchMinSS THEN
	    #temp_bldPitchRef := "Inst_PeakS".g_bldPitchMinSS;
	END_IF;
	
	// sumamos el efecto del IPC
	FOR #temp_i := 0 TO 2 DO
	    #stat_bldPitches[#temp_i] := #temp_bldPitchRef + LREAL_TO_REAL("IPC_prueba".PitComIPC_1P[#temp_i]);
	END_FOR;
	
	
	// si esta en modo manual, hacer caso a la variable del SCADA 
	IF NOT "DatosGlobales".g_bldPitchAutoMode THEN
	    FOR #temp_i := 0 TO 2 DO
	        #stat_bldPitches[#temp_i] := "DatosGlobales".g_bldPitchManualValue * (1.0 / #RAD_TO_DEG);
	    END_FOR;
	END_IF;
	
	
	// si está apagado y se enciende.
	IF #stat_shutdown_ok AND NOT "DatosGlobales".g_paroEmerg THEN
	    
	    //Modo manual, control del operario
	    "DatosGlobales".g_torqAutoMode := FALSE;
	    "DatosGlobales".g_bldPitchAutoMode := FALSE;
	    
	    //1.- se coloca a 20 grados. 
	    FOR #temp_i := 0 TO 2 DO
	        #stat_bldPitches[#temp_i] := 15.0 * (1.0 / #RAD_TO_DEG);
	    END_FOR;
	    IF #temp_genSpeed_rads >= #VS_REGION_1 THEN //2.- se espera a que el rotor coja inercia.
	        FOR #temp_i := 0 TO 2 DO //3.- pitch a 0
	            #stat_bldPitches[#temp_i] := 0.0;
	        END_FOR;
	        IF #stat_lastBldPitches[0] < (1.0 * (1.0 / #RAD_TO_DEG)) THEN
	            "DatosGlobales".g_torqAutoMode := TRUE;
	            "DatosGlobales".g_bldPitchAutoMode := TRUE;
	            #stat_shutdown_ok := FALSE;
	        END_IF;
	    
	    
	
	    END_IF;
	END_IF;
	
	
	// si se pulsa la seta de emergencia
	IF "DatosGlobales".g_paroEmerg THEN
	    #stat_shutdown_ok := FALSE;
	    "DatosGlobales".g_torqAutoMode := FALSE;
	    "DatosGlobales".g_bldPitchAutoMode := FALSE;
	    
	    FOR #temp_i := 0 TO 2 DO
	        #stat_bldPitches[#temp_i] := #MAX_PITCH; // consigna de 90 grados (parada)
	    END_FOR;
	    IF #i_genSpeed_rpm < 100.0 THEN
	        #stat_shutdown_ok := TRUE;
	    END_IF;
	    
	    
	END_IF;
	
	//visualizar en scada (BARRA)
	"DatosGlobales".g_bldPitchManualValue := REAL_TO_INT(#stat_bldPitches[0] * #RAD_TO_DEG);
	
	//tasa de cambio y limite superior a todas las palas
	
	FOR #temp_i := 0 TO 2 DO
	    #temp_bldPitchRate := (#stat_bldPitches[#temp_i] - #stat_lastBldPitches[#temp_i]) / #DTIME;
	    IF #temp_bldPitchRate > #MAX_PITCH_RATE THEN
	        #stat_bldPitches[#temp_i] := #stat_lastBldPitches[#temp_i] + #MAX_PITCH_RATE * #DTIME;
	    ELSIF #temp_bldPitchRate < - #MAX_PITCH_RATE THEN
	        #stat_bldPitches[#temp_i] := #stat_lastBldPitches[#temp_i] - #MAX_PITCH_RATE * #DTIME;
	    END_IF;
	    IF #stat_bldPitches[#temp_i] > #MAX_PITCH THEN
	        #stat_bldPitches[#temp_i] := #MAX_PITCH;
	    END_IF;
	    #temp_bldPitchRate := 0.0; //inicializo
	END_FOR;
	
	// creo una variable para visualizarla en grados en el scada (GRAFICA)
	#stat_lastBldPitch_deg := #stat_bldPitches[0] * #RAD_TO_DEG;
	// salida hacia simulink
	#q_bldPitch1_rad := #stat_bldPitches[0];
	#q_bldPitch2_rad := #stat_bldPitches[1];
	#q_bldPitch3_rad := #stat_bldPitches[2];
	
	// guardo los ultimos valores
	#stat_lastBldPitches[0] := #q_bldPitch1_rad;
	#stat_lastBldPitches[1] := #q_bldPitch2_rad;
	#stat_lastBldPitches[2] := #q_bldPitch3_rad;
	
	//ultimo valor del CPC
	#stat_lastBldPitch := #temp_bldPitchRef;
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_IPC"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_rootMyc1 : LReal;
      i_rootMyc2 : LReal;
      i_rootMyc3 : LReal;
      i_genSpeed : LReal;
      i_azimuth : LReal;
      i_wind_flt : LReal;
      i_enable : Bool;
   END_VAR

   VAR_OUTPUT 
      q_pitComIPC_1P : Array[0..2] of LReal;
   END_VAR

   VAR 
      stat_IPC_KP : Real := 0.0;
      stat_IPC_KI : Real := 1.025E-06;
      stat_IntIPC : Real := 0.3;
      stat_windStartIPC : Real := 9.12;
      stat_windStopIPC : Real := 11.4;
   END_VAR

   VAR_TEMP 
      temp_rootMOOP : Array[1..3] of LReal;
      temp_axTOut : Real;
      temp_axYOut : Real;
      temp_FA_PitCom : LReal;
      temp_IPC_Kp_1p : Real;
      temp_IPC_Ki_1p : Real;
      temp_IPC_axisTilt_1P : LReal;
      temp_IPC_axisYaw_1P : LReal;
      temp_rootMycF1_flt : LReal;
      temp_rootMycF2_flt : LReal;
      temp_rootMycF3_flt : LReal;
   END_VAR

   VAR CONSTANT 
      DTIME : Real := 0.0125;
      DEG_TO_RAD : Real := 0.0174532;
      RPM_TO_RADS : Real := 0.1047197;
      DAMP : Real := 0.7;
   END_VAR


BEGIN
	
	
	"inst_NotchFilterSlopes1"(i_signal := #i_rootMyc1,
	                          i_DT := #DTIME,
	                          i_freq := (#i_genSpeed * #RPM_TO_RADS),
	                          i_damp := #DAMP,
	                          i_status := 1,
	                          i_moving := "DatosGlobales".g_bldPitchAutoMode,
	                          q_signal_flt => #temp_rootMycF1_flt);
	"inst_NotchFilterSlopes2"(i_signal := #i_rootMyc2,
	                          i_DT := #DTIME,
	                          i_freq := #i_genSpeed * #RPM_TO_RADS,
	                          i_damp := #DAMP,
	                          i_status := 1,
	                          i_moving := "DatosGlobales".g_bldPitchAutoMode,
	                          q_signal_flt => #temp_rootMycF2_flt);
	"inst_NotchFilterSlopes3"(i_signal := #i_rootMyc3,
	                          i_DT := #DTIME,
	                          i_freq := #i_genSpeed * #RPM_TO_RADS,
	                          i_damp := #DAMP,
	                          i_status := 1,
	                          i_moving := "DatosGlobales".g_bldPitchAutoMode,
	                          q_signal_flt => #temp_rootMycF3_flt);
	#temp_rootMOOP[1] := #temp_rootMycF1_flt;
	#temp_rootMOOP[2] := #temp_rootMycF2_flt;
	#temp_rootMOOP[3] := #temp_rootMycF3_flt;
	"FC_ColemanTransform"(i_rootMOOP := #temp_rootMOOP,
	                      i_aziAngle := #i_azimuth * #DEG_TO_RAD,
	                      i_nHarmonic := 1,
	                      q_axTOut => #temp_axTOut,
	                      q_axYOut => #temp_axYOut);
	
	#temp_IPC_Kp_1p := "FC_Sigma"(x := #i_wind_flt, x0 := #stat_windStartIPC, x1 := #stat_windStopIPC, y0 := 0.0, y1 := #stat_IPC_KP);
	#temp_IPC_Ki_1p := "FC_Sigma"(x := #i_wind_flt, x0 := #stat_windStartIPC, x1 := #stat_windStopIPC, y0 := 0.0, y1 := #stat_IPC_KI);
	
	"inst_PI_IPC_T"(i_error := #temp_axTOut,
	                i_kp := #temp_IPC_Kp_1p,
	                i_ki := #temp_IPC_Ki_1p,
	                i_minValue := - #stat_IntIPC,
	                i_maxValue := #stat_IntIPC,
	                i_DT := #DTIME,
	                i_I0 := 0.0,
	                i_Reset := NOT "DatosGlobales".g_bldPitchAutoMode, //poner NOT pitchAuto (si esta en manual se resetea)
	                //i_Reset := "Inst_PitchController".stat_shutdown_ok,
	                q_PIController => #temp_IPC_axisTilt_1P);
	
	"inst_PI_IPC_Y"(i_error := #temp_axYOut,
	                i_kp := #temp_IPC_Kp_1p,
	                i_ki := #temp_IPC_Ki_1p,
	                i_minValue := - #stat_IntIPC,
	                i_maxValue := #stat_IntIPC,
	                i_DT := #DTIME,
	                i_I0 := 0.0,
	                i_Reset := NOT "DatosGlobales".g_bldPitchAutoMode, //poner NOT pitchAuto (si esta en manual se resetea)
	                q_PIController => #temp_IPC_axisYaw_1P);
	
	"FC_ColemanTransformInverse"(i_axTIn := #temp_IPC_axisTilt_1P,
	                             i_axYIn := #temp_IPC_axisYaw_1P,
	                             i_aziAngle := #i_azimuth * #DEG_TO_RAD,
	                             i_aziOffset := 0.0,
	                             i_nHarmonic := 1,
	                             q_pitComIPC => #q_pitComIPC_1P);
	IF #i_enable THEN
	    
	    #q_pitComIPC_1P[0] := 0.0;
	    #q_pitComIPC_1P[1] := 0.0;
	    #q_pitComIPC_1P[2] := 0.0;
	    
	END_IF;
	
	
	
	
END_FUNCTION_BLOCK

