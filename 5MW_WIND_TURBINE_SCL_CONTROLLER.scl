FUNCTION_BLOCK "FB_HPFilter"
TITLE = 'Filtro Paso Alto de Primer Orden (Discreto)'
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_signal : LReal;
      i_DT : LReal;
      i_freq : LReal;
      i_reset : Bool;
      i_useInicialValue : Bool;
      i_initialValue : LReal;
   END_VAR

   VAR_OUTPUT 
      q_fignal_flt : LReal;
   END_VAR

   VAR 
      FirstRun : Bool := TRUE;
      InputSignalLast : LReal;
      OutputSignalLast : LReal;
      Coeff_X0 : LReal;
      Coeff_X1 : LReal;
      Coeff_Y1 : LReal;
   END_VAR

   VAR_TEMP 
      temp_initVal : LReal;
      temp_k : LReal;
      temp_denom : LReal;
   END_VAR


BEGIN
	    IF #i_useInicialValue THEN
	        #temp_initVal := #i_initialValue;
	    ELSE
	        #temp_initVal := #i_signal;
	    END_IF;
	    IF #FirstRun OR #i_reset THEN
	        #OutputSignalLast := #temp_initVal;
	        #InputSignalLast := #temp_initVal;
	        #temp_k := 2.0 / #i_DT;
	        #temp_denom := #i_freq + #temp_k;
	        
	        #Coeff_X0 := #temp_k / #temp_denom;
	        #Coeff_X1 := - #temp_k / #temp_denom;
	        #Coeff_Y1 := - ((#i_freq - #temp_k) / #temp_denom);
	        
	        #FirstRun := FALSE;
	    END_IF;
	    
	#q_fignal_flt := (#Coeff_X0 * #i_signal) + (#Coeff_X1 * #InputSignalLast) + (#Coeff_Y1 * #OutputSignalLast);
	#InputSignalLast := #i_signal;
	#OutputSignalLast := #q_fignal_flt;
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB_PIController"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_error : Real;
      i_kp : Real;
      i_ki : Real;
      i_minValue : Real;
      i_maxValue : Real;
      i_DT : Real;
      i_I0 : Real;
      i_Reset : Bool;
   END_VAR

   VAR_OUTPUT 
      q_PIController : Real;
   END_VAR

   VAR 
      stat_integral : Real;
      stat_ITerm : Real;
      stat_ITermLast : Real;
   END_VAR

   VAR_TEMP 
      temp_proporcional : Real;
      temp_q_notSat : Real;
      temp_PTerm : Real;
   END_VAR


BEGIN
	// Bumpless transfer
	IF #i_Reset THEN
	    #stat_ITerm := #i_I0;
	    #stat_ITermLast := #i_I0;
	    #q_PIController := #i_I0;
	        
	ELSE
	    // Termino proporcional
	    #temp_PTerm := #i_kp * #i_error;
	    
	    // Termino integral
	    #stat_ITerm := #stat_ITerm + (#i_DT * #i_ki * #i_error);
	    
	    // Anti-Windup aplicado al termino integral
	    #stat_ITerm := LIMIT(MN := #i_minValue, IN := #stat_ITerm, MX := #i_maxValue);
	    
	    // Salida final saturada
	    #q_PIController := LIMIT(MN := #i_minValue, IN := (#temp_PTerm + #stat_ITerm), MX := #i_maxValue);
	    
	    // Guardado del estado anterior
	    #stat_ITermLast := #stat_ITerm;
	    
	END_IF;
END_FUNCTION_BLOCK

