VERSION : 0.1
NON_RETAIN
"FB_IPC"

BEGIN

END_DATA_BLOCK

FUNCTION "FC_PeakShaving" : Real
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_wind_flt : Real;
      i_numPuntos : Int;
      i_tablaVientos : Array[*] of Real;
      i_tablaPitch : Array[*] of Real;
      i_enable : Bool;
   END_VAR

   VAR_TEMP 
      i : Int;
      Pitch_Peak_Shaving : Real;
      x0 : Real;
      x1 : Real;
      y0 : Real;
      y1 : Real;
      Limite_Inferior_Array : DInt;
   END_VAR


BEGIN
	#Limite_Inferior_Array := LOWER_BOUND(ARR := #i_tablaVientos, DIM := 1);
	
	IF #i_wind_flt <= #i_tablaVientos[#Limite_Inferior_Array] THEN
	    #Pitch_Peak_Shaving := #i_tablaPitch[#Limite_Inferior_Array];
	ELSIF #i_wind_flt >= #i_tablaVientos[#Limite_Inferior_Array + #i_numPuntos - 1] THEN
	    #Pitch_Peak_Shaving := #i_tablaPitch[#Limite_Inferior_Array + #i_numPuntos - 1];
	ELSE
	    FOR #i := DINT_TO_INT(#Limite_Inferior_Array) TO (DINT_TO_INT(#Limite_Inferior_Array) + #i_numPuntos - 2) DO
	        IF (#i_wind_flt >= #i_tablaVientos[#i]) AND (#i_wind_flt < #i_tablaVientos[#i + 1]) THEN
	            #x0 := #i_tablaVientos[#i];
	            #x1 := #i_tablaVientos[#i + 1];
	            #y0 := #i_tablaPitch[#i];
	            #y1 := #i_tablaPitch[#i + 1];
	            IF (#x1 - #x0) <> 0.0 THEN
	                #Pitch_Peak_Shaving := #y0 + ((#i_wind_flt - #x0) * (#y1 - #y0) / (#x1 - #x0));
	            ELSE
	                #Pitch_Peak_Shaving := #y0;
	            END_IF;
	            EXIT;
	        END_IF;
	        
	    END_FOR;
	END_IF;
	
	IF #i_enable THEN
	    IF #Pitch_Peak_Shaving > 0.0 THEN
	        #FC_PeakShaving := #Pitch_Peak_Shaving;
	    ELSE
	        #FC_PeakShaving := 0.0;
	    END_IF;
	ELSE
	    #FC_PeakShaving := 0.0;
	END_IF;
	
	
END_FUNCTION

